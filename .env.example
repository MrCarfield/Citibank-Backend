# ==================== 应用基础配置 ====================
# 应用名称（将显示在文档标题中）
APP_NAME=Citibank Backend API
# 应用版本号（仅用于展示）
APP_VERSION=0.1.0
# 应用描述（OpenAPI 文档描述）
APP_DESCRIPTION=Citibank 后端服务 API

# ==================== 服务运行配置 ====================
# 服务监听地址，生产环境通常为 0.0.0.0
HOST=0.0.0.0
# 服务监听端口
PORT=8091
# API 统一前缀，当前项目使用 /v1
API_V1_PREFIX=/v1

# 是否开启调试模式（True 开启，False 关闭）
DEBUG=True

# CORS 允许的前端域名列表（如需限制前端来源可在此配置）
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# ==================== 数据库与缓存配置 ====================
# -------- Redis 配置（用于 ZKP 挑战存储等） --------
# Redis 主机地址
REDIS_HOST=redis
# Redis 端口
REDIS_PORT=6379
# Redis 数据库序号
REDIS_DB=0
# Redis 密码（如无密码可留空）
REDIS_PASSWORD=
# 如需手动指定完整 Redis URL，可在代码中扩展使用
# REDIS_URL=redis://redis:6379/0

# -------- MySQL 配置（业务数据存储） --------
# MySQL 主机地址
MYSQL_HOST=mysql
# MySQL 端口
MYSQL_PORT=3306
# MySQL root 账户密码（仅初始化或运维时使用）
MYSQL_ROOT_PASSWORD=root123
# 应用使用的数据库用户名
MYSQL_USER=citibank
# 应用使用的数据库密码
MYSQL_PASSWORD=citibank123
# 应用使用的数据库名称
MYSQL_DATABASE=citibank_db
# 如需直接使用完整连接串，可在代码中扩展使用
# MYSQL_URL=mysql+pymysql://citibank:citibank123@mysql:3306/citibank_db

# ==================== 其他通用配置 ====================
# 后端默认时区
TZ=Asia/Shanghai

# -------- JWT / 鉴权配置 --------
# JWT 签名密钥（生产环境必须替换为高强度随机字符串）
SECRET_KEY=your-secret-key-here
# JWT 签名算法
ALGORITHM=HS256
# 访问 Token 过期时间（分钟），如不设置则使用代码默认值
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== LLM Council（多模型议会）配置 ====================
# OpenRouter API Key，用于调用多家大模型形成“AI 议会”
# 仅在使用 Translator 接口、多模型讨论功能时必需
OPENROUTER_API_KEY=your-openrouter-api-key

# 可选：自定义参与议会的模型列表（逗号分隔）
# COUNCIL_MODELS=openai/gpt-4o,google/gemini-1.5-pro,anthropic/claude-3.5-sonnet,x-ai/grok-2-1212
# 可选：最终“主席模型”，用于综合各模型意见
# CHAIRMAN_MODEL=google/gemini-1.5-pro

# ==================== 豆包大模型配置 (火山引擎) ====================
# 豆包 LLM 接口地址（如不使用豆包，可留空或忽略）
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses
# 豆包 API Key（用于 Forecast/RM 报告相关 LLM 功能）
DOUBAO_API_KEY=your-doubao-api-key
# 豆包模型名称
DOUBAO_MODEL=doubao-seed-1-8-251228

# ==================== 其他外部服务配置（可选） ====================
# 某些实验性/扩展功能使用的第三方 API Key（如不使用可留空）
EASYIMPR_API_KEY=your-easyimpr-api-key

# 必应 / 营销类搜索相关 Key（如不使用可留空）
BING_YING_SEARCH=your-bing-search-key

# ==================== 油价神经网络（MT-RiskNet）配置 ====================
# 说明：
# - 已将 oil_risk 代码与训练产物完整拷贝到当前项目：
#   代码:      app/ml/oil_risk/
#   模型产物:  artifacts/oil_risk/h1~h10/
# - 下列配置主要影响数据采集与日志，不影响模型结构本身。

# 产物目录（包含各 horizon 的 mt_risknet.pt / scaler.joblib / meta.json）
# 如不配置，默认使用项目内路径：artifacts/oil_risk
OIL_ARTIFACTS_DIR=artifacts/oil_risk

# ------ 外部数据源 API（可选，但强烈建议在生产环境配置） ------
# FRED API Key，用于获取宏观与价格数据（未配置时使用安全模拟序列）
FRED_API_KEY=
# EIA API Key，用于获取库存等能源数据（未配置时使用安全模拟序列或兜底数据）
EIA_API_KEY=
# 自定义 EIA v2 接口 URL（如使用自定义库存数据源可配置）
EIA_INVENTORY_URL=
# EIA 自定义接口中数值字段名称（默认 value）
EIA_INVENTORY_FIELD=value

# ------ GDELT 事件与新闻因子（可选） ------
# GDELT 查询关键词（如 "oil OR OPEC OR crude"）
OIL_GDELT_QUERY=
# 从最近多少天内拉取 GDELT 事件（默认 365）
OIL_GDELT_DAYS=365
# GDELT 语言过滤（如 "english"，留空表示不过滤）
OIL_GDELT_LANG=
# 事件日历文件路径（相对当前项目），用于关键事件解释
OIL_EVENT_CALENDAR_PATH=app/ml/oil_risk/event_calendar.json

# ------ 模型运行与日志相关配置（可选） ------
# 是否允许使用 Yahoo 价格作为兜底数据源（0 禁用，1 启用）
OIL_USE_YAHOO=0
# 油模内部日志级别（DEBUG/INFO/WARN/ERROR）
OIL_LOG_LEVEL=INFO

# 历史数据起始日期（影响数据采集区间，格式 YYYY-MM-DD）
OIL_START_DATE=2015-01-01
# 历史数据结束日期（留空表示使用最新可用日期）
OIL_END_DATE=

# 预测窗口（天），影响加载 hN 目录；通常由业务 horizon 决定，可保持默认
OIL_FORECAST_HORIZON=5
# 序列回看窗口长度（影响时间序列样本长度，训练时使用）
OIL_LOOKBACK=20

# 以下训练相关参数一般只在重新训练模型时使用，线上推理可保持默认：
# OIL_TRAIN_RATIO=0.8          # 训练集比例
# OIL_BATCH_SIZE=64            # batch 大小
# OIL_LR=1e-3                  # 学习率
# OIL_EPOCHS=30                # 训练轮数
# OIL_SEED=42                  # 随机种子
